# Bot token from Discord Developer Portal → Bot → Token
DISCORD_TOKEN=

# Application ID (same as "Client ID" on the OAuth2 → General page)
CLIENT_ID=

# Optional: register slash commands only in this server (instant updates while developing)
# Leave unset to register commands globally (can take up to ~1 hour to appear everywhere)
GUILD_ID=

# Channel where quote messages are collected (right-click channel → Copy Channel ID)
QUOTES_CHANNEL_ID=
